{
  "name": "daterly",
  "version": "1.0.0",
  "type": "module",
  "description": "daterly — React date & time picker с маской ввода, диапазонами и опциональной интеграцией react-hook-form.",
  "keywords": [
    "daterly",
    "react",
    "datepicker",
    "date-picker",
    "time-picker",
    "react-hook-form",
    "date-range"
  ],
  "author": "Artemy",
  "license": "MIT",
  "homepage": "https://artemydottech.github.io/daterly",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artemydottech/daterly.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./rhf": {
      "types": "./dist/rhf.d.ts",
      "import": "./dist/rhf.js",
      "require": "./dist/rhf.cjs"
    },
    "./styles": "./dist/styles/variables.css"
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    ".",
    "docs"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config=playwright-ct.config.ts",
    "changeset": "changeset",
    "cs:version": "changeset version",
    "release": "tsup && changeset publish",
    "prepare": "husky"
  },
  "dependencies": {
    "date-fns": "^4.0.0",
    "react-day-picker": "^9.0.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-hook-form": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "react-hook-form": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/experimental-ct-react": "^1.59.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "antd": "^6.3.7",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-hook-form": "^7.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
